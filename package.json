{
  "name": "nexcall",
  "version": "1.0.3",
  "description": "Secure 1-to-1 video calling app — all 4 phases",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "gen-certs": "openssl req -nodes -new -x509 -keyout server.key -out server.cert -subj '/CN=localhost'",
    "setup": "npm install && npm run gen-certs",
    "test": "jest"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^8.2.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "supertest": "^7.2.2",
    "ws": "^8.20.0"
  }
}
